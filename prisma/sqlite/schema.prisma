generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Auth.js 需要这些模型保存管理员账号和已绑定的 Passkey。
// 账号仍只会由成功的管理员密码登录创建，不开放任何注册入口。
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  authenticators Authenticator[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  createdAt            DateTime @default(now())
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialID])
}

model Source {
  id          String   @id @default(cuid())
  name        String   @unique
  baseUrl     String
  enabled     Boolean  @default(true)
  timeoutMs   Int      @default(30000)
  userAgent   String?
  headersJson String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  routes      Route[]
}

model Route {
  id          String   @id @default(cuid())
  pathPrefix  String   @unique
  targetPath  String
  enabled     Boolean  @default(true)
  isPublic    Boolean  @default(true)
  name        String
  description String?
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs        DownloadLog[]

  @@index([enabled, isPublic])
}

model DownloadLog {
  id         String   @id @default(cuid())
  routeId    String?
  route      Route?   @relation(fields: [routeId], references: [id], onDelete: SetNull)
  sourceName String
  path       String
  status     Int
  durationMs Int
  bytes      BigInt   @default(0)
  clientIp   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([routeId, createdAt])
}
