{
  "name": "fetch-bridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "preview:cloudflare:download": "wrangler dev --config wrangler.download.jsonc --local",
    "deploy:cloudflare": "npm run deploy:cloudflare:app && npm run deploy:cloudflare:download",
    "deploy:cloudflare:app": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
    "deploy:cloudflare:download": "wrangler deploy --config wrangler.download.jsonc",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv",
    "cf:typegen:download": "wrangler types workers/download-env.d.ts --config wrangler.download.jsonc --env-file workers/.env.typegen --env-interface DownloadWorkerEnv --include-runtime=false",
    "test:relay": "node --import tsx --test lib/relay-core.test.ts",
    "check:cloudflare:download": "npm run cf:typegen:download && npm run test:relay && wrangler deploy --config wrangler.download.jsonc --dry-run",
    "db:d1:migrate:local": "wrangler d1 migrations apply fetch-bridge --local",
    "db:d1:migrate:remote": "wrangler d1 migrations apply fetch-bridge --remote",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "wrangler d1 execute fetch-bridge --local --file prisma/seed.sql"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@opennextjs/cloudflare": "1.20.2",
    "@prisma/adapter-d1": "6.19.3",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "4.113.0"
  }
}
