{
  "name": "fetch-bridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "vercel-build": "npm run db:generate:postgres && npm run db:migrate:postgres:deploy && npm run db:seed:postgres && next build",
    "deploy:vercel": "npx --yes vercel@latest --prod",
    "deploy:vercel:preview": "npx --yes vercel@latest",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "PRISMA_TARGET=sqlite prisma generate",
    "db:generate:postgres": "PRISMA_TARGET=postgres prisma generate",
    "db:migrate": "PRISMA_TARGET=sqlite prisma migrate dev",
    "db:migrate:deploy": "PRISMA_TARGET=sqlite prisma migrate deploy",
    "db:migrate:postgres": "PRISMA_TARGET=postgres prisma migrate dev",
    "db:migrate:postgres:deploy": "PRISMA_TARGET=postgres prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:postgres": "PRISMA_TARGET=postgres tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
